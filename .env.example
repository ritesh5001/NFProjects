# =====================================================================
# NextGen Fusion mobile app (Expo) — environment.
# This app is SEPARATE from the website. It does NOT read Backend/.env
# or Frontend/.env. Only variables prefixed with EXPO_PUBLIC_ are exposed
# to the app, and they are inlined into the build at compile time.
#
# Copy this file to .env and set the URL of the DEPLOYED Express backend
# (the same server the website talks to) — NOT the Next.js site / proxy,
# because the proxy strips the Authorization header the app sends.
# =====================================================================

# Base URL of the Express backend.
#   Production:                 https://your-backend.onrender.com
#   iOS simulator / web (dev):  http://localhost:4000
#   Android emulator (dev):     http://10.0.2.2:4000
#   Physical phone (dev):       http://<your-computer-LAN-IP>:4000  (e.g. http://192.168.1.5:4000)
EXPO_PUBLIC_API_BASE_URL=https://your-backend-url
